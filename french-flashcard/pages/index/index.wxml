<view class="page">
  <view class="title">我的课本</view>
  <view class="book-list">
    <view
      class="card book-item"
      wx:for="{{books}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onTapBook"
    >
      <text class="book-icon">{{item.icon}}</text>
      <text class="book-title">{{item.title}}</text>
      <text class="book-count">{{item.lessons.length}} 课</text>
    </view>
  </view>
</view>
