.page {
  padding: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
  color: #1e1e1e;
}

.lesson-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.lesson-item {
  padding: 32rpx;
}

.lesson-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.lesson-title {
  font-size: 32rpx;
  color: #1e1e1e;
}

.lesson-progress {
  font-size: 24rpx;
  color: #364fc7;
}

.progress-bar {
  height: 8rpx;
  background: #e8ecf4;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #364fc7;
  border-radius: 4rpx;
  transition: width 0.3s;
}
